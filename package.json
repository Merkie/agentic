{
  "name": "@merkie/agentic",
  "version": "0.1.0",
  "description": "Opinionated streamText-first framework for building AI agents in JS.",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "dev:send-message": "tsx examples/send-message.ts",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.182",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
